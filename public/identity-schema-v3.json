{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlascrew.dev/schemas/identity-v3.1.json",
  "title": "Professional Identity Schema v3.1",
  "description": "Portable professional identity model for Facet and related agent workflows.",
  "type": "object",
  "required": [
    "version",
    "identity",
    "self_model",
    "preferences",
    "skills",
    "profiles",
    "roles",
    "projects",
    "education",
    "generator_rules"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "number", "const": 3 },
    "schema_revision": { "type": "string", "enum": ["3.1"] },
    "identity": { "$ref": "#/$defs/IdentityCore" },
    "self_model": { "$ref": "#/$defs/SelfModel" },
    "preferences": { "$ref": "#/$defs/Preferences" },
    "skills": { "$ref": "#/$defs/Skills" },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/Profile" }
    },
    "roles": {
      "type": "array",
      "items": { "$ref": "#/$defs/Role" }
    },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/Project" }
    },
    "education": {
      "type": "array",
      "items": { "$ref": "#/$defs/EducationEntry" }
    },
    "generator_rules": { "$ref": "#/$defs/GeneratorRules" },
    "search_vectors": {
      "type": "array",
      "items": { "$ref": "#/$defs/SearchVector" }
    },
    "awareness": { "$ref": "#/$defs/Awareness" }
  },
  "$defs": {
    "TagList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ImpactList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "TechnologyList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "MetricValue": {
      "type": ["string", "number", "boolean"]
    },
    "SkillDepth": {
      "type": "string",
      "enum": ["expert", "strong", "working", "basic", "avoid"]
    },
    "SkillEnrichedBy": {
      "type": "string",
      "enum": ["user", "user-edited-llm", "llm-accepted"]
    },
    "SearchVectorPriority": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "AwarenessSeverity": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "MatchingWeight": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "MatchingSeverity": {
      "type": "string",
      "enum": ["hard", "soft"]
    },
    "IdentityLink": {
      "type": "object",
      "required": ["id", "url"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "IdentityCore": {
      "type": "object",
      "required": ["name", "email", "phone", "location", "links", "thesis"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "display_name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "remote": { "type": "boolean" },
        "title": { "type": "string" },
        "links": {
          "type": "array",
          "items": { "$ref": "#/$defs/IdentityLink" }
        },
        "thesis": { "type": "string" },
        "elaboration": { "type": "string" },
        "origin": { "type": "string" }
      }
    },
    "ArcEntry": {
      "type": "object",
      "required": ["company", "chapter"],
      "additionalProperties": false,
      "properties": {
        "company": { "type": "string" },
        "chapter": { "type": "string" }
      }
    },
    "PhilosophyEntry": {
      "type": "object",
      "required": ["id", "text", "tags"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "tags": { "$ref": "#/$defs/TagList" }
      }
    },
    "InterviewStyle": {
      "type": "object",
      "required": ["strengths", "weaknesses", "prep_strategy"],
      "additionalProperties": false,
      "properties": {
        "strengths": { "$ref": "#/$defs/TagList" },
        "weaknesses": { "$ref": "#/$defs/TagList" },
        "prep_strategy": { "type": "string" }
      }
    },
    "SelfModel": {
      "type": "object",
      "required": ["arc", "philosophy", "interview_style"],
      "additionalProperties": false,
      "properties": {
        "arc": {
          "type": "array",
          "items": { "$ref": "#/$defs/ArcEntry" }
        },
        "philosophy": {
          "type": "array",
          "items": { "$ref": "#/$defs/PhilosophyEntry" }
        },
        "interview_style": { "$ref": "#/$defs/InterviewStyle" }
      }
    },
    "CompPriority": {
      "type": "object",
      "required": ["item", "weight"],
      "additionalProperties": false,
      "properties": {
        "item": { "type": "string" },
        "weight": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "CompensationPreferences": {
      "type": "object",
      "required": ["priorities"],
      "additionalProperties": false,
      "properties": {
        "base_floor": { "type": "number" },
        "base_target": { "type": "number" },
        "notes": { "type": "string" },
        "priorities": {
          "type": "array",
          "items": { "$ref": "#/$defs/CompPriority" }
        }
      }
    },
    "WorkModelPreferences": {
      "type": "object",
      "required": ["preference"],
      "additionalProperties": false,
      "properties": {
        "preference": { "type": "string" },
        "flexibility": { "type": "string" },
        "hard_no": { "type": "string" }
      }
    },
    "RoleFitPreferences": {
      "type": "object",
      "required": ["ideal", "red_flags", "evaluation_criteria"],
      "additionalProperties": false,
      "properties": {
        "ideal": { "$ref": "#/$defs/TagList" },
        "red_flags": { "$ref": "#/$defs/TagList" },
        "evaluation_criteria": { "$ref": "#/$defs/TagList" }
      }
    },
    "MatchingPriority": {
      "type": "object",
      "required": ["id", "label", "description", "weight"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "weight": { "$ref": "#/$defs/MatchingWeight" }
      }
    },
    "MatchingAvoid": {
      "type": "object",
      "required": ["id", "label", "description", "severity"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "$ref": "#/$defs/MatchingSeverity" }
      }
    },
    "MatchingPreferences": {
      "type": "object",
      "required": ["prioritize", "avoid"],
      "additionalProperties": false,
      "properties": {
        "prioritize": {
          "type": "array",
          "items": { "$ref": "#/$defs/MatchingPriority" }
        },
        "avoid": {
          "type": "array",
          "items": { "$ref": "#/$defs/MatchingAvoid" }
        }
      }
    },
    "ClearanceConstraint": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string" },
        "willing_to_obtain": { "type": "boolean" },
        "exclude_required": { "type": "boolean" }
      }
    },
    "EducationConstraint": {
      "type": "object",
      "required": ["highest"],
      "additionalProperties": false,
      "properties": {
        "highest": { "type": "string" },
        "in_progress": { "type": "string" },
        "show_on_resume": { "type": "boolean" },
        "filter_risk": { "type": "string" }
      }
    },
    "PreferenceConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clearance": { "$ref": "#/$defs/ClearanceConstraint" },
        "education": { "$ref": "#/$defs/EducationConstraint" },
        "title_flexibility": { "$ref": "#/$defs/TagList" }
      }
    },
    "Preferences": {
      "type": "object",
      "required": ["compensation", "work_model", "role_fit"],
      "additionalProperties": false,
      "properties": {
        "compensation": { "$ref": "#/$defs/CompensationPreferences" },
        "work_model": { "$ref": "#/$defs/WorkModelPreferences" },
        "role_fit": { "$ref": "#/$defs/RoleFitPreferences" },
        "constraints": { "$ref": "#/$defs/PreferenceConstraints" },
        "matching": { "$ref": "#/$defs/MatchingPreferences" }
      }
    },
    "SkillItem": {
      "type": "object",
      "required": ["name", "tags"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "depth": { "$ref": "#/$defs/SkillDepth" },
        "proficiency": { "type": "string" },
        "context": { "type": "string" },
        "search_signal": { "type": "string" },
        "tags": { "$ref": "#/$defs/TagList" },
        "enriched_at": { "type": "string" },
        "enriched_by": { "$ref": "#/$defs/SkillEnrichedBy" },
        "skipped_at": { "type": "string" }
      }
    },
    "SkillGroup": {
      "type": "object",
      "required": ["id", "label", "items"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "positioning": { "type": "string" },
        "is_differentiator": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/SkillItem" }
        }
      }
    },
    "Skills": {
      "type": "object",
      "required": ["groups"],
      "additionalProperties": false,
      "properties": {
        "groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/SkillGroup" }
        }
      }
    },
    "Profile": {
      "type": "object",
      "required": ["id", "tags", "text"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "tags": { "$ref": "#/$defs/TagList" },
        "text": { "type": "string" }
      }
    },
    "BulletMetrics": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/MetricValue" }
    },
    "RoleBullet": {
      "type": "object",
      "required": [
        "id",
        "problem",
        "action",
        "outcome",
        "impact",
        "metrics",
        "technologies",
        "tags"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "problem": { "type": "string" },
        "action": { "type": "string" },
        "outcome": { "type": "string" },
        "impact": { "$ref": "#/$defs/ImpactList" },
        "metrics": { "$ref": "#/$defs/BulletMetrics" },
        "technologies": { "$ref": "#/$defs/TechnologyList" },
        "portfolio_dive": { "type": ["string", "null"] },
        "tags": { "$ref": "#/$defs/TagList" },
        "source_text": { "type": "string" }
      }
    },
    "Role": {
      "type": "object",
      "required": ["id", "company", "title", "dates", "bullets"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "company": { "type": "string" },
        "subtitle": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "dates": { "type": "string" },
        "portfolio_anchor": { "type": ["string", "null"] },
        "bullets": {
          "type": "array",
          "items": { "$ref": "#/$defs/RoleBullet" }
        }
      }
    },
    "Project": {
      "type": "object",
      "required": ["id", "name", "description", "tags"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "portfolio_dive": { "type": ["string", "null"] },
        "tags": { "$ref": "#/$defs/TagList" }
      }
    },
    "EducationEntry": {
      "type": "object",
      "required": ["school", "location", "degree"],
      "additionalProperties": false,
      "properties": {
        "school": { "type": "string" },
        "location": { "type": "string" },
        "degree": { "type": "string" },
        "year": { "type": "string" }
      }
    },
    "GeneratorRules": {
      "type": "object",
      "required": ["voice_skill", "resume_skill"],
      "additionalProperties": false,
      "properties": {
        "voice_skill": { "type": "string" },
        "resume_skill": { "type": "string" },
        "accuracy": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        }
      }
    },
    "SearchVectorKeywords": {
      "type": "object",
      "required": ["primary", "secondary"],
      "additionalProperties": false,
      "properties": {
        "primary": { "$ref": "#/$defs/TagList" },
        "secondary": { "$ref": "#/$defs/TagList" }
      }
    },
    "SearchVector": {
      "type": "object",
      "required": ["id", "title", "priority", "thesis", "target_roles", "keywords"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "priority": { "$ref": "#/$defs/SearchVectorPriority" },
        "subtitle": { "type": "string" },
        "thesis": { "type": "string" },
        "target_roles": { "$ref": "#/$defs/TagList" },
        "keywords": { "$ref": "#/$defs/SearchVectorKeywords" },
        "supporting_skills": { "$ref": "#/$defs/TagList" },
        "supporting_bullets": { "$ref": "#/$defs/TagList" }
      }
    },
    "OpenQuestion": {
      "type": "object",
      "required": ["id", "topic", "description", "action"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string" },
        "description": { "type": "string" },
        "action": { "type": "string" },
        "severity": { "$ref": "#/$defs/AwarenessSeverity" }
      }
    },
    "Awareness": {
      "type": "object",
      "required": ["open_questions"],
      "additionalProperties": false,
      "properties": {
        "open_questions": {
          "type": "array",
          "items": { "$ref": "#/$defs/OpenQuestion" }
        }
      }
    }
  }
}
