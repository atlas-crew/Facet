# Local proxy defaults
PORT=9001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FACET_AUTH_MODE=local

# Anthropic proxy settings
ANTHROPIC_API_KEY=replace-me
MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096
MAX_REQUEST_TOKENS=4096
MAX_BODY_BYTES=1048576
DEFAULT_TEMPERATURE=
THINKING_BUDGET=0

# Local-only request gate. Do not treat this as a production secret once sent by a browser client.
PROXY_API_KEY=facet-local-proxy

# Local-only persistence bearer token mapping. Ignored when FACET_AUTH_MODE=hosted.
PERSISTENCE_AUTH_TOKENS=[{"token":"facet-local-user","tenantId":"tenant-local","userId":"user-local","workspaces":["facet-local-workspace"]}]

# Hosted auth settings. Use these when FACET_AUTH_MODE=hosted.
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
HOSTED_MEMBERSHIP_FILE=./hosted-membership.example.json
HOSTED_BILLING_FILE=./hosted-billing.example.json
STRIPE_SECRET_KEY=
STRIPE_PRICE_AI_MONTHLY=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/settings/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/settings/billing/cancel
